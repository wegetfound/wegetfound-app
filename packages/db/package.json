{
  "name": "@wegetfound/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx --env-file=../../.env src/migrate.ts",
    "rls": "tsx --env-file=../../.env src/apply-rls.ts",
    "studio": "drizzle-kit studio",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "score-loop": "tsx --env-file=../../.env src/score-loop.ts",
    "provision-auth": "tsx --env-file=../../.env src/provision-auth-user.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo \"(eslint configured at root)\""
  },
  "dependencies": {
    "@wegetfound/ai-adapters": "workspace:*",
    "@wegetfound/audit": "workspace:^",
    "@wegetfound/scoring": "workspace:*",
    "@wegetfound/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  }
}
