# wegetfound.ai — environment contract
# Copy to .env for local dev. NEVER commit .env (see CLAUDE.md §13).
# In CI/prod these are injected via Doppler or Infisical, not a file.

# --- Database / Auth (Supabase) ---
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, bypasses RLS for system jobs (§7.10)
SUPABASE_JWT_SECRET=

# --- Cache & Queue (Redis + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- AI engine adapters (§6.4) ---
OPENAI_API_KEY=                   # chatgpt-adapter
PERPLEXITY_API_KEY=               # perplexity-adapter (Sonar)
ANTHROPIC_API_KEY=                # claude-adapter (reference impl)
GOOGLE_AI_API_KEY=                # gemini-adapter
SERPAPI_KEY=                      # google-aio-adapter (AI Overviews)

# --- Payments (Stripe, test mode first) ---
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PUBLISHABLE_KEY=pk_test_

# --- Email ---
RESEND_API_KEY=                   # transactional
LOOPS_API_KEY=                    # lifecycle / drip

# --- Integrations ---
GOOGLE_PLACES_API_KEY=            # onboarding autocomplete (§10)

# --- Observability ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- App config ---
NODE_ENV=development
API_PORT=3001
WEB_URL=http://localhost:5173
MARKETING_URL=http://localhost:4321
SCORE_METHODOLOGY_VERSION=v1.0
