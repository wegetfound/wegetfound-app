# wegetfound.ai — environment contract
# Copy to .env for local dev. NEVER commit .env (see CLAUDE.md §13).
# In CI/prod these are injected via Doppler or Infisical, not a file.

# --- Database / Auth (Supabase) ---
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=                # sb_publishable_... (safe to expose in browser)
SUPABASE_SERVICE_ROLE_KEY=        # sb_secret_... — server-only, bypasses RLS (§7.10)
# JWT verification uses JWKS endpoint (ECC P-256) — no shared secret needed

# --- Cache & Queue (Redis + BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- AI engine adapters (§6.4) ---
OPENAI_API_KEY=                   # chatgpt-adapter
PERPLEXITY_API_KEY=               # perplexity-adapter (Sonar)
ANTHROPIC_API_KEY=                # claude-adapter (reference impl)
GOOGLE_AI_API_KEY=                # gemini-adapter
SERPAPI_KEY=                      # google-aio-adapter (AI Overviews)

# --- Payments (Stripe) ---
# Get keys from https://dashboard.stripe.com/apikeys (test mode)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# Price IDs from Stripe Dashboard → Products → [Product] → Prices
# Format: price_xxxxx (e.g., price_1OsHyVFakePriceId)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_here
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual_here
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly_here
STRIPE_PRICE_GROWTH_ANNUAL=price_growth_annual_here
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly_here
STRIPE_PRICE_AGENCY_ANNUAL=price_agency_annual_here

# --- Email ---
RESEND_API_KEY=                   # transactional
LOOPS_API_KEY=                    # lifecycle / drip

# --- Integrations ---
GOOGLE_PLACES_API_KEY=            # onboarding autocomplete (§10)

# --- Observability ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- App config ---
NODE_ENV=development
API_PORT=3001
WEB_URL=http://localhost:5173
MARKETING_URL=http://localhost:4321
SCORE_METHODOLOGY_VERSION=v1.0
